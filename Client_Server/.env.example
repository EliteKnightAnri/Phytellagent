# 示例 .env 文件（不要把真实密钥提交到版本库）
# 复制为 `.env` 并填写实际值：

# DeepSeek / OpenAI
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 如果代码或第三方库使用 OPENAI_API_KEY，可一并配置
OPENAI_API_KEY=

# MCP 配置（相对路径或绝对路径）
MCP_SETTINGS_PATH=./mcp_settings.json

# FAISS / Embeddings（如使用本地索引或目录）
FAISS_INDEX_DIR=./faiss_store/files

# 数据库（若使用 MySQL）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# 后端绑定地址与端口
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# 其他可选设置：LOG_LEVEL, SENTRY_DSN 等
# LOG_LEVEL=INFO
# SENTRY_DSN=
